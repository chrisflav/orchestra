# Copy to `.env` in this directory; docker compose reads it automatically.
# Do not commit the filled-in copy — it holds tokens.

# --- taxis (required) ---
# The instance backing projects, issues and claims. A container cannot reach the host's
# localhost, so `http://localhost:8080` will not work from inside — use one of:
#   http://host.docker.internal:8080   (with extra_hosts: host-gateway, see README)
#   http://taxis:8080                  (taxis on a shared docker network)
#   http://<host-lan-ip>:8080
ORCHESTRA_TAXIS_URL=http://host.docker.internal:8080
# API token for a taxis actor with admin rights — orchestra creates the t-project and o-* labels
# on first use, which requires admin. Mint one with POST /api/me/tokens.
ORCHESTRA_TAXIS_TOKEN=

# --- GitHub (both are needed) ---
# These are not alternatives. A real setup wants both, because they do different jobs.
#
# The App is required to run any task at all: every task mints an installation token from it and
# hands that to `gh` for cloning and pushing. Without it a task fails before the agent starts.
# Put the downloaded .pem in ./secrets/ (gitignored, mounted read-only at /secrets) and give the
# path *inside the container*.
ORCHESTRA_GITHUB_APP_ID=
ORCHESTRA_GITHUB_PRIVATE_KEY_PATH=/secrets/github-app.pem
# Override to keep keys somewhere other than ./secrets — any host directory works.
#ORCHESTRA_SECRETS_DIR=/etc/orchestra/secrets
#
# The PAT covers what the installation token cannot: opening pull requests against the *upstream*
# repository, plus issue comments, PR reviews, and the triage backend. Needs repo scope. Omit it
# only if you never target upstream and never use those tools.
ORCHESTRA_GITHUB_PAT=

# --- Agent auth (pick one) ---
ORCHESTRA_CLAUDE_TOKEN=
ORCHESTRA_ANTHROPIC_API_KEY=

# --- DNS (optional) ---
# Upstream resolver for the container. Leave empty to use the host's, which is almost always
# right. Set one address (only one is supported) if tasks fail with
# "error connecting to api.github.com" while curl from inside the container works — see the
# troubleshooting section in docker/README.md.
#ORCHESTRA_DNS=1.1.1.1
ORCHESTRA_DNS=

# --- Dashboard (optional) ---
# The web dashboard runs as its own container and serves HTML + JSON on one port.
#
# Every /api and /sse request must present this token. Leave it empty to have one generated on
# first start and persisted to data/orchestra/dashboard.token; the container prints it, so
# `docker compose logs dashboard` is the quickest way to read it. The dashboard asks for it in
# the browser once and keeps it in localStorage.
ORCHESTRA_DASHBOARD_TOKEN=
# Host port to publish it on.
#ORCHESTRA_DASHBOARD_PORT=8080
# Host interface to publish it on. The default (loopback) means only the machine running Docker
# can reach it, which is what you want without TLS in front — the API is plain HTTP and gated
# only by the token above. Widen it only behind a reverse proxy.
#ORCHESTRA_DASHBOARD_BIND=0.0.0.0
