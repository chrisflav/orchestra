# Copy to `.env` in this directory; docker compose reads it automatically.
# Do not commit the filled-in copy — it holds tokens.

# --- taxis (required) ---
# The instance backing projects, issues and claims. A container cannot reach the host's
# localhost, so `http://localhost:8080` will not work from inside — use one of:
#   http://host.docker.internal:8080   (with extra_hosts: host-gateway, see README)
#   http://taxis:8080                  (taxis on a shared docker network)
#   http://<host-lan-ip>:8080
ORCHESTRA_TAXIS_URL=http://host.docker.internal:8080
# API token for a taxis actor with admin rights — orchestra creates the t-project and o-* labels
# on first use, which requires admin. Mint one with POST /api/me/tokens.
ORCHESTRA_TAXIS_TOKEN=

# --- GitHub (pick one) ---
# Simple: a personal access token with repo scope.
ORCHESTRA_GITHUB_PAT=
# Or a GitHub App. Put the downloaded .pem in ./secrets/ (gitignored, mounted read-only at
# /secrets) and give its path *inside the container* below. Leave empty when using a PAT.
ORCHESTRA_GITHUB_APP_ID=0
#ORCHESTRA_GITHUB_PRIVATE_KEY_PATH=/secrets/github-app.pem
ORCHESTRA_GITHUB_PRIVATE_KEY_PATH=
# Override to keep keys somewhere other than ./secrets — any host directory works.
#ORCHESTRA_SECRETS_DIR=/etc/orchestra/secrets

# --- Agent auth (pick one) ---
ORCHESTRA_CLAUDE_TOKEN=
ORCHESTRA_ANTHROPIC_API_KEY=

# --- DNS (optional) ---
# Upstream resolver for the container. Leave empty to use the host's, which is almost always
# right. Set one address (only one is supported) if tasks fail with
# "error connecting to api.github.com" while curl from inside the container works — see the
# troubleshooting section in docker/README.md.
#ORCHESTRA_DNS=1.1.1.1
ORCHESTRA_DNS=
